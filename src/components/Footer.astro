---
// Footer — site-wide footer with contact info, service list, and service areas
import site from '../data/site.json';
import serviceAreas from '../data/serviceAreas.json';
const year = new Date().getFullYear();
---

<footer class="mt-20">
  <!-- Pre-footer CTA strip -->
  <div style="background-color: var(--color-brand-navy);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-14 flex flex-col sm:flex-row items-center justify-between gap-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest mb-2" style="color: var(--color-brand-accent);">Free Estimates — Joshua, TX</p>
        <p class="font-bold leading-tight" style="font-family: var(--font-family-display); font-size: clamp(1.4rem, 3vw, 2rem); color: #ffffff;">
          Ready to stop worrying about your gutters?
        </p>
        <p class="text-sm mt-2" style="color: rgba(255,255,255,0.65);">Same-day estimates. 5-year written warranty. No subcontractors.</p>
      </div>
      <div class="flex flex-col sm:flex-row items-center gap-3 shrink-0">
        <a href="/contact" class="cta-primary inline-flex items-center justify-center px-7 py-3.5 rounded font-semibold text-sm whitespace-nowrap">
          Get a Free Estimate
        </a>
        <a href={site.phoneLink} class="inline-flex items-center justify-center px-7 py-3.5 rounded font-semibold text-sm whitespace-nowrap border" style="border-color: rgba(255,255,255,0.25); color: #ffffff; transition: border-color 0.15s ease, background-color 0.15s ease;" onmouseover="this.style.borderColor='rgba(254,134,54,0.5)';this.style.backgroundColor='rgba(254,134,54,0.1)';" onmouseout="this.style.borderColor='rgba(255,255,255,0.25)';this.style.backgroundColor='transparent';">
          {site.phone}
        </a>
      </div>
    </div>
  </div>

  <!-- Footer body -->
  <div class="border-t" style="background-color: var(--color-surface-base); border-color: var(--color-border);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10">

      <!-- Brand column -->
      <div class="md:col-span-1">
        <a href="/" aria-label="Beacon Rain Control — Home">
          <img src="/logo.svg" alt="Beacon Rain Control" class="h-10 w-auto mb-4" />
        </a>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-content-muted);">
          Seamless gutter installation and repair serving Johnson County and Tarrant County, TX.
        </p>
        <a href={site.phoneLink} class="text-base font-semibold hover:underline" style="color: var(--color-brand-accent-dark);">
          {site.phone}
        </a>
        <p class="text-xs mt-1" style="color: var(--color-content-muted);">{site.hours}</p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-brand-accent);">Services</h3>
        <ul class="space-y-2">
          {site.services.map((s) => (
            <li>
              <a href={`/services#${s.slug}`} class="footer-link text-sm">{s.name}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Service areas -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-brand-accent);">Service Areas</h3>
        <ul class="space-y-2">
          {serviceAreas.slice(0, 6).map((area) => (
            <li>
              <a href={`/${area.slug}`} class="footer-link text-sm">{area.city}</a>
            </li>
          ))}
          <li>
            <a href="/service-areas" class="footer-link text-sm font-semibold">All service areas →</a>
          </li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-brand-accent);">Contact</h3>
        <address class="not-italic space-y-2">
          <p class="text-sm" style="color: var(--color-content-muted);">
            {site.address.street}<br />
            {site.address.city}, {site.address.state} {site.address.zip}
          </p>
          <p><a href={site.phoneLink} class="footer-link text-sm">{site.phone}</a></p>
          <p><a href={`mailto:${site.email}`} class="footer-link text-sm">{site.email}</a></p>
        </address>
      </div>
    </div>

    <div class="border-t mt-10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4" style="border-color: var(--color-border);">
      <p class="text-xs" style="color: var(--color-content-muted);">
        &copy; {year} Beacon Rain Control. All rights reserved.
      </p>
      <p class="text-xs" style="color: var(--color-content-muted);">
        Joshua, TX 76058 &mdash; Licensed &amp; Insured
      </p>
    </div>
  </div>
  </div>
</footer>
