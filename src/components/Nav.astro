---
// Nav — site-wide navigation with logo, links, CTA button, and mobile hamburger
import site from '../data/site.json';

const { pathname } = Astro.url;
const navLinks = [
  { href: '/services', label: 'Services' },
  { href: '/about',    label: 'About' },
  { href: '/contact',  label: 'Contact' },
];
---

<header class="sticky top-0 z-40 border-b" style="background-color: var(--color-surface-base); border-color: var(--color-border);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Beacon Rain Control — Home">
        <img src="/logo.svg" alt="Beacon Rain Control" class="h-9 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Primary navigation">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class="nav-link text-sm font-medium"
            aria-current={pathname.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center gap-4">
        <a href={site.phoneLink} class="nav-link text-sm font-semibold">
          {site.phone}
        </a>
        <a href="/contact" class="nav-cta text-sm font-semibold px-4 py-2 rounded border">
          Get a Free Estimate
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="nav-toggle"
        class="md:hidden p-2 rounded"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
        style="color: var(--color-content-primary);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path id="hamburger-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="hamburger-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t"
    style="background-color: var(--color-surface-base); border-color: var(--color-border);"
  >
    <nav class="flex flex-col px-4 py-4 gap-1" aria-label="Mobile navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="text-sm font-medium px-2 py-2.5 rounded"
          aria-current={pathname.startsWith(href) ? 'page' : undefined}
          style={pathname.startsWith(href)
            ? 'color: var(--color-brand-accent);'
            : 'color: var(--color-content-primary);'}
        >
          {label}
        </a>
      ))}
      <div class="border-t mt-2 pt-4" style="border-color: var(--color-border);">
        <a href={site.phoneLink} class="text-sm font-semibold py-2 block" style="color: var(--color-brand-accent);">
          {site.phone}
        </a>
        <a href="/contact" class="nav-cta mt-3 text-sm font-semibold px-4 py-3 rounded border text-center block">
          Get a Free Estimate
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('mobile-menu');
  const open = document.getElementById('hamburger-open');
  const close = document.getElementById('hamburger-close');

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    open?.classList.toggle('hidden');
    close?.classList.toggle('hidden');
  });
</script>
