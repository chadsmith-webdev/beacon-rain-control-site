---
// Nav — site-wide navigation with logo, links, CTA button, and mobile hamburger
import site from '../data/site.json';

const { pathname } = Astro.url;
const navLinks = [
  { href: '/services',     label: 'Services' },
  { href: '/about',        label: 'About' },
  { href: '/service-areas', label: 'Areas' },
  { href: '/seamless-vs-sectional-gutters', label: 'Learn' },
  { href: '/contact',      label: 'Contact' },
];
---

<header class="sticky top-0 z-40 border-b" style="background-color: var(--color-surface-base); border-color: var(--color-border);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0" aria-label="Beacon Rain Control — Home">
        <img src="/logo.svg" alt="Beacon Rain Control" class="h-9 w-auto" />
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Primary navigation">
        {navLinks.map(({ href, label }) => (
          <a
            href={href}
            class="nav-link text-sm font-medium"
            aria-current={pathname.startsWith(href) ? 'page' : undefined}
          >
            {label}
          </a>
        ))}
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden md:flex items-center gap-4">
        <a href={site.phoneLink} class="nav-link text-sm font-semibold" aria-label={`Call Beacon Rain Control in Joshua, TX: ${site.phone}`}>
          {site.phone}
        </a>
        <a href="/contact" class="nav-cta text-sm font-semibold px-4 py-2 rounded border" aria-label="Request a free gutter estimate in Joshua, TX">
          Get a Free Estimate in Joshua, TX
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button
        id="nav-toggle"
        class="md:hidden p-3 rounded"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Open navigation menu"
        style="color: var(--color-content-primary);"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path id="hamburger-open" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          <path id="hamburger-close" class="hidden" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu — CSS-animated, starts closed -->
  <div
    id="mobile-menu"
    class="mobile-menu md:hidden border-t"
    aria-hidden="true"
    style="background-color: var(--color-surface-base); border-color: var(--color-border);"
  >
    <nav class="flex flex-col px-4 py-4 gap-1" aria-label="Mobile navigation">
      {navLinks.map(({ href, label }) => (
        <a
          href={href}
          class="mobile-nav-link text-sm font-medium px-2 py-2.5 rounded"
          aria-current={pathname.startsWith(href) ? 'page' : undefined}
          style={pathname.startsWith(href)
            ? 'color: var(--color-brand-navy); font-weight: 600;'
            : 'color: var(--color-content-primary);'}
          tabindex="-1"
        >
          {label}
        </a>
      ))}
      <div class="border-t mt-2 pt-4" style="border-color: var(--color-border);">
        <a
          href={site.phoneLink}
          class="text-sm font-semibold py-2 block"
          style="color: var(--color-brand-accent);"
          aria-label={`Call Beacon Rain Control in Joshua, TX: ${site.phone}`}
          tabindex="-1"
        >
          {site.phone}
        </a>
        <a
          href="/contact"
          class="nav-cta mt-3 text-sm font-semibold px-4 py-3 rounded border text-center block"
          aria-label="Request a free gutter estimate in Joshua, TX"
          tabindex="-1"
        >
          Get a Free Estimate in Joshua, TX
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  const header = document.querySelector('header');
  if (header) {
    window.addEventListener('scroll', () => {
      header.style.boxShadow = window.scrollY > 10
        ? '0 1px 12px rgba(40,59,119,0.10)'
        : '';
    }, { passive: true });
  }
</script>

<style>
  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height 0.3s ease, opacity 0.2s ease;
  }
  .mobile-menu.is-open {
    max-height: 600px;
    opacity: 1;
  }
  .mobile-nav-link {
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .mobile-nav-link:hover {
    color: var(--color-brand-navy) !important;
    background-color: var(--color-brand-tint);
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('hamburger-open');
  const closeIcon = document.getElementById('hamburger-close');

  function getFocusables(): HTMLElement[] {
    return [...(menu?.querySelectorAll('a, button') ?? [])] as HTMLElement[];
  }

  function openMenu() {
    menu?.classList.add('is-open');
    menu?.setAttribute('aria-hidden', 'false');
    toggle?.setAttribute('aria-expanded', 'true');
    openIcon?.classList.add('hidden');
    closeIcon?.classList.remove('hidden');
    // Enable tab access and focus first link after transition begins
    getFocusables().forEach(el => el.removeAttribute('tabindex'));
    requestAnimationFrame(() => getFocusables()[0]?.focus());
  }

  function closeMenu() {
    menu?.classList.remove('is-open');
    menu?.setAttribute('aria-hidden', 'true');
    toggle?.setAttribute('aria-expanded', 'false');
    openIcon?.classList.remove('hidden');
    closeIcon?.classList.add('hidden');
    // Remove from tab order when closed
    getFocusables().forEach(el => el.setAttribute('tabindex', '-1'));
    toggle?.focus();
  }

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('is-open');
    isOpen ? closeMenu() : openMenu();
  });

  // Escape closes the menu
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('is-open')) {
      closeMenu();
    }
  });

  // Close menu on any nav link click (page navigation)
  getFocusables().forEach(el => {
    if (el.tagName === 'A') {
      el.addEventListener('click', closeMenu);
    }
  });
</script>
