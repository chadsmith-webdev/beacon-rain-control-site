---
// Homepage — hero, services, trust signals, testimonials, process, gallery, service areas, CTA
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import site from '../data/site.json';

import heroImg        from '../assets/images/seamless-gutter.jpg';
import fabricationImg from '../assets/images/copper-gutter-fabrication.webp';
import galleryImg1    from '../assets/images/residential-seamless-gutter-installation1.jpg';
import galleryImg2    from '../assets/images/brc-seamlessgutter_installation.jpg';
import galleryImg3    from '../assets/images/seemlass-gutter-installation-2.jpg';

const title = 'Seamless Gutter Installation in Joshua, TX | Beacon Rain Control';
const description = 'Beacon Rain Control installs seamless aluminum gutters in Joshua, Burleson, Cleburne, and throughout Johnson County, TX. Free estimates. 5-year warranty. Call (817) 681-6041.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: site.name,
  telephone: site.phone,
  email: site.email,
  url: site.siteUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.state,
    postalCode: site.address.zip,
    addressCountry: 'US',
  },
  areaServed: site.serviceAreas,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.rating,
    reviewCount: site.reviewCount,
  },
  openingHours: 'Mo-Sa 08:00-18:00',
};

const testimonials = [
  {
    quote: "Mr. Neff was courteous, responsive, and extremely knowledgeable when I reached out for a quote. His team did exceptional work and left the area clean when the job was complete. They provide a 5-year warranty on their work. Absolutely a great company — I will use Beacon Rain Control exclusively for all related work going forward.",
    author: "Beth James",
  },
  {
    quote: "Tracy was professional from beginning to end. They did a great job, showed up on time and cleaned up when they were done. I highly recommend Beacon Rain Control!",
    author: "Cecilia",
  },
  {
    quote: "Came out and got me a quote the same day I called. Professional and efficient, did a great job.",
    author: "Jake Bransford",
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="min-height: clamp(560px, 70vh, 760px);">

    <!-- Background image -->
    <Image
      src={heroImg}
      alt=""
      width={1400}
      height={800}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      aria-hidden="true"
    />

    <!-- Gradient overlay: heavy on left where text sits, lighter on right so the photo breathes -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(100deg, rgba(9,11,18,0.88) 0%, rgba(9,11,18,0.72) 45%, rgba(9,11,18,0.40) 100%), linear-gradient(to top, rgba(9,11,18,0.70) 0%, transparent 40%);"
      aria-hidden="true"
    ></div>

    <!-- Content -->
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center" style="min-height: clamp(560px, 70vh, 760px);">
      <div class="max-w-xl py-20">
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-brand-accent);">
          Seamless Gutter Installation • Joshua, TX & Johnson County
        </p>
        <h1 class="font-bold leading-tight mb-6" style="font-family: var(--font-family-display); font-size: clamp(2rem, 5vw, 3.25rem); letter-spacing: -0.02em; color: #ffffff;">
          Stop Water Damage Before It Starts—Expert Gutter Installation in Joshua, TX
        </h1>
        <p class="text-lg leading-relaxed mb-8" style="color: rgba(242,241,239,0.85);">
          Leaking or overflowing gutters can destroy your foundation, landscaping, and fascia. Beacon Rain Control installs seamless aluminum gutters—custom cut on-site for your home, built to handle Texas storms, and backed by a 5-year warranty. Serving Joshua, Burleson, Cleburne, and all of Johnson County.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="cta-primary inline-flex items-center justify-center px-7 py-3.5 rounded font-semibold text-sm" aria-label="Request a free gutter estimate in Joshua, TX">
            Get a Free Estimate in Joshua, TX
          </a>
          <a href={site.phoneLink} class="hero-cta-ghost inline-flex items-center justify-center px-7 py-3.5 rounded font-semibold text-sm border" aria-label="Call Beacon Rain Control now for a same-day quote: {site.phone}">
            Call Now for Same-Day Quote
          </a>
        </div>
        <p class="text-xs mt-4" style="color: rgba(242,241,239,0.55);">Locally owned • Free estimates • {site.warranty} warranty</p>
      </div>
    </div>

    <!-- Bottom fade into next section -->
    <div class="absolute bottom-0 left-0 right-0 h-16" style="background: linear-gradient(to bottom, transparent, var(--color-surface-bg));" aria-hidden="true"></div>
  </section>

  <!-- Trust bar as marquee strip -->
  <section style="background-color: var(--color-surface-base); border-bottom: 1px solid var(--color-border);">
    <div class="overflow-x-hidden py-3" aria-label="Trust signals">
      <div class="relative w-full">
        <ul class="marquee-track flex items-center gap-8 min-w-max" role="list" aria-hidden="true">
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Star icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Top-rated in Joshua, TX</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">{site.rating} stars on Google &bull; {site.reviewCount} reviews</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Home icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.707 2.293a1 1 0 00-1.414 0l-7 7A1 1 0 003 11h1v5a2 2 0 002 2h2a1 1 0 001-1v-3h2v3a1 1 0 001 1h2a2 2 0 002-2v-5h1a1 1 0 00.707-1.707l-7-7z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Locally owned &amp; operated</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Serving Johnson County homeowners</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Shield/award icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 2c-.28 0-.56.06-.82.18l-5 2.22A2 2 0 003 6.22V10c0 5.25 6.13 7.72 6.4 7.82a1 1 0 00.8 0C10.87 17.72 17 15.25 17 10V6.22a2 2 0 00-1.18-1.82l-5-2.22A1.98 1.98 0 0010 2zm0 2.06l5 2.22V10c0 4.13-4.13 6.13-5 6.54-.87-.41-5-2.41-5-6.54V6.28l5-2.22z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">{site.warranty} warranty</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">On every installation</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Phone/bolt icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M2.003 5.884l2-3.5A1 1 0 015 2h10a1 1 0 01.997 1.116l-2 14A1 1 0 0113 18H7a1 1 0 01-.997-1.116l2-14A1 1 0 017 2h6a1 1 0 01.997 1.116l-2 14A1 1 0 0113 18H7a1 1 0 01-.997-1.116l2-14A1 1 0 017 2z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Free same-day estimates</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Call or request online</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Check badge icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 2a2 2 0 00-2 2v1.586l-2.293 2.293a1 1 0 000 1.414l1.293 1.293a1 1 0 001.414 0L10 8.414l1.586 1.586a1 1 0 001.414 0l1.293-1.293a1 1 0 000-1.414L12 5.586V4a2 2 0 00-2-2zm-1 7.414l-1.293-1.293a3 3 0 010-4.242l1.293-1.293a3 3 0 014.242 0l1.293 1.293a3 3 0 010 4.242L11 9.414a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Licensed &amp; insured</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Peace of mind, every job</span>
          </li>
          <!-- Duplicate for infinite scroll -->
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Star icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Top-rated in Joshua, TX</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">{site.rating} stars on Google &bull; {site.reviewCount} reviews</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Home icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.707 2.293a1 1 0 00-1.414 0l-7 7A1 1 0 003 11h1v5a2 2 0 002 2h2a1 1 0 001-1v-3h2v3a1 1 0 001 1h2a2 2 0 002-2v-5h1a1 1 0 00.707-1.707l-7-7z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Locally owned &amp; operated</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Serving Johnson County homeowners</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Shield/award icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 2c-.28 0-.56.06-.82.18l-5 2.22A2 2 0 003 6.22V10c0 5.25 6.13 7.72 6.4 7.82a1 1 0 00.8 0C10.87 17.72 17 15.25 17 10V6.22a2 2 0 00-1.18-1.82l-5-2.22A1.98 1.98 0 0010 2zm0 2.06l5 2.22V10c0 4.13-4.13 6.13-5 6.54-.87-.41-5-2.41-5-6.54V6.28l5-2.22z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">{site.warranty} warranty</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">On every installation</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Phone/bolt icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M2.003 5.884l2-3.5A1 1 0 015 2h10a1 1 0 01.997 1.116l-2 14A1 1 0 0113 18H7a1 1 0 01-.997-1.116l2-14A1 1 0 017 2h6a1 1 0 01.997 1.116l-2 14A1 1 0 0113 18H7a1 1 0 01-.997-1.116l2-14A1 1 0 017 2z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Free same-day estimates</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Call or request online</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Check badge icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10 2a2 2 0 00-2 2v1.586l-2.293 2.293a1 1 0 000 1.414l1.293 1.293a1 1 0 001.414 0L10 8.414l1.586 1.586a1 1 0 001.414 0l1.293-1.293a1 1 0 000-1.414L12 5.586V4a2 2 0 00-2-2zm-1 7.414l-1.293-1.293a3 3 0 010-4.242l1.293-1.293a3 3 0 014.242 0l1.293 1.293a3 3 0 010 4.242L11 9.414a1 1 0 01-1.414 0z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Licensed &amp; insured</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Peace of mind, every job</span>
          </li>
        </ul>
      </div>
    </div>
    <style>
      @media (min-width: 640px) {
        .marquee-track {
          display: flex;
          width: max-content;
          animation: marquee-infinite 32s linear infinite;
        }
        @keyframes marquee-infinite {
          0% { transform: translateX(0); }
          100% { transform: translateX(-50%); }
        }
      }
    </style>
  </section>

  <!-- Services -->
  <section class="py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">What We Do</p>
        <h2 class="font-bold" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
          Gutter services built around your home
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {site.services.map((service) => (
          <article class="service-card rounded-xl p-6 border flex flex-col gap-3">
            <h3 class="font-semibold text-base" style="color: var(--color-content-primary);">{service.name}</h3>
            <p class="text-sm leading-relaxed flex-1" style="color: var(--color-content-muted);">{service.description}</p>
            <a href={`/services#${service.slug}`} class="text-sm font-semibold hover:underline mt-auto" style="color: var(--color-brand-accent);" aria-label={`Learn more about ${service.name} in Joshua, TX`}>
              Learn More
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Beacon -->
  <section class="py-20 md:py-24" style="background-color: var(--color-surface-base); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">Why Beacon</p>
          <h2 class="font-bold mb-6" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
            Gutters you don't have to think about again
          </h2>
          <p class="text-base leading-relaxed mb-6" style="color: var(--color-content-muted);">
            Most gutter problems start with gutters that weren't built for the home they're on. Beacon Rain Control measures and cuts every gutter on-site — no pre-made sections, no exposed seams where water collects and leaks.
          </p>
          <p class="text-base leading-relaxed" style="color: var(--color-content-muted);">
            Every job is backed by a {site.warranty} warranty. If something isn't right, we come back and make it right.
          </p>
        </div>
        <div class="grid grid-cols-1 gap-4">
          {[
            { label: 'Same-day quotes', detail: 'Most estimates are turned around the same day you call.' },
            { label: 'On time, every time', detail: 'Customers consistently note we show up when we say we will.' },
            { label: 'Clean jobsite', detail: 'We haul everything out — no debris left behind.' },
            { label: '5-year warranty', detail: 'All gutter installations are backed by a written warranty.' },
          ].map((item) => (
            <div class="rounded-xl p-5 border flex gap-4 items-start" style="background-color: var(--color-surface-raised); border-color: var(--color-border-strong);">
              <div class="mt-0.5 w-5 h-5 rounded-full flex items-center justify-center shrink-0" style="background-color: var(--color-brand-tint);" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3" style="color: var(--color-brand-accent);">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold mb-0.5" style="color: var(--color-content-primary);">{item.label}</p>
                <p class="text-sm" style="color: var(--color-content-muted);">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">What Customers Say</p>
        <h2 class="font-bold" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
          The work speaks for itself
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map((t) => (
          <figure class="rounded-xl p-6 border flex flex-col gap-4" style="background-color: var(--color-surface-base); border-color: var(--color-border);">
            <div class="flex gap-0.5" aria-label="5 out of 5 stars">
              {Array(5).fill(null).map(() => (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" style="color: var(--color-brand-accent);" aria-hidden="true">
                  <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
                </svg>
              ))}
            </div>
            <blockquote class="text-sm leading-relaxed flex-1" style="color: var(--color-content-muted);">
              &ldquo;{t.quote}&rdquo;
            </blockquote>
            <figcaption class="text-xs font-semibold" style="color: var(--color-content-primary);">
              &mdash; {t.author}
            </figcaption>
          </figure>
        ))}
      </div>
      <p class="text-xs text-center mt-6" style="color: var(--color-content-muted);">
        From Google Business Profile &bull; {site.rating} stars &bull; {site.reviewCount} reviews
      </p>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20 md:py-24" style="background-color: var(--color-surface-base); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-xl">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">How It Works</p>
        <h2 class="font-bold" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
          From first call to finished gutters
        </h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 mb-12">
        {[
          { step: '01', title: 'Free estimate', body: 'Call or email — we come out, measure your roofline, and give you a straight quote. No pressure, no obligation.' },
          { step: '02', title: 'Custom fabrication on-site', body: 'We cut and form your gutters on-site from a continuous run of aluminum. Fit to your home, not off a shelf.' },
          { step: '03', title: 'Clean install, clean yard', body: 'Gutters go up, old materials come down, and we clean up before we leave. You get a warranty card and a clean gutterline.' },
        ].map((item) => (
          <div class="flex flex-col gap-4">
            <div class="text-3xl font-bold" style="font-family: var(--font-family-mono); color: var(--color-brand-accent); opacity: 0.5;" aria-hidden="true">
              {item.step}
            </div>
            <h3 class="text-lg font-semibold" style="color: var(--color-content-primary);">{item.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-content-muted);">{item.body}</p>
          </div>
        ))}
      </div>
      <!-- On-site fabrication photo -->
      <div class="rounded-xl overflow-hidden" style="border: 1px solid var(--color-border);">
        <Image
          src={fabricationImg}
          alt="Tracy fabricating seamless gutters on-site with a gutter machine"
          width={1200}
          height={675}
          class="w-full h-auto"
        />
      </div>
    </div>
  </section>

  <!-- Work gallery -->
  <section class="py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">Our Work</p>
        <h2 class="font-bold" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
          Real homes in Johnson County
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { src: galleryImg1, alt: "Seamless gutter installation on a two-story brick home" },
          { src: galleryImg2, alt: "Beacon Rain Control technician installing gutters on a stone home" },
          { src: galleryImg3, alt: "Gutter installation in progress on a brick ranch home" },
        ].map(({ src, alt }) => (
          <div class="group rounded-xl overflow-hidden" style="border: 1px solid var(--color-border); aspect-ratio: 4/3;">
            <Image
              src={src}
              alt={alt}
              width={600}
              height={450}
              class="w-full h-full object-cover transition-transform duration-500 ease-out group-hover:scale-105"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service areas -->
  <section class="py-20 md:py-24" style="background-color: var(--color-surface-base); border-top: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">Where We Work</p>
        <h2 class="font-bold" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
          Serving Johnson County and Tarrant County
        </h2>
      </div>
      <div class="flex flex-wrap gap-3">
        {site.serviceAreas.map((area) => (
          <span class="text-sm px-3 py-1.5 rounded-full border" style="border-color: var(--color-border-strong); color: var(--color-content-muted); background-color: var(--color-surface-raised);">
            {area}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-bold mb-4" style="font-family: var(--font-family-display); font-size: clamp(1.75rem, 4vw, 2.75rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
        Ready to stop worrying about your gutters?
      </h2>
      <p class="text-lg mb-8 max-w-xl mx-auto" style="color: var(--color-content-muted);">
        Free estimates, no contracts, {site.warranty} warranty. Call or fill out the form — we'll get back to you the same day.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="cta-primary inline-flex items-center justify-center px-8 py-4 rounded font-semibold">
          Get a Free Estimate
        </a>
        <a href={site.phoneLink} class="cta-secondary inline-flex items-center justify-center px-8 py-4 rounded font-semibold border">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
</BaseLayout>
