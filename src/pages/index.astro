  </section>

  <!-- FAQ -->
  <section class="py-24 md:py-32" style="background-color: var(--color-surface-base); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10" data-reveal>
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">Common Questions</p>
        <h2 class="section-h2">
          Questions about gutters in Johnson County
        </h2>
        <p class="text-xs mt-3" style="color: var(--color-content-muted);">Last updated: April 28, 2026</p>
      </div>
      <div class="divide-y" style="border-color: var(--color-border);">
        {faqItems.map((item) => (
          <details class="group py-1">
            <summary class="faq-summary flex items-center justify-between gap-6 py-4 cursor-pointer list-none">
              <span class="text-sm font-semibold leading-snug" style="color: var(--color-content-primary);">{item.q}</span>
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="faq-chevron w-4 h-4 shrink-0 transition-transform duration-200" style="color: var(--color-brand-accent);" aria-hidden="true">
                <path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 011.06 0L10 11.94l3.72-3.72a.75.75 0 111.06 1.06l-4.25 4.25a.75.75 0 01-1.06 0L5.22 9.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
              </svg>
            </summary>
            <div class="pb-5">
              <p class="text-sm leading-relaxed" style="color: var(--color-content-muted);">{item.a}</p>
              {item.link && (
                <a href={item.link.href} class="inline-block mt-2 text-sm font-semibold hover:underline" style="color: var(--color-brand-accent);">
                  {item.link.text}
                </a>
              )}
            </div>
          </details>
        ))}
      </div>
    </div>
    <style>
      .faq-summary { list-style: none; }
      .faq-summary::-webkit-details-marker { display: none; }
      details[open] .faq-chevron { transform: rotate(180deg); }
    </style>
  </section>

  <!-- Service areas -->
  <section class="py-24 md:py-32" style="background-color: var(--color-surface-base); border-top: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10" data-reveal>
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">Where We Work</p>
        <h2 class="section-h2">
          Serving Johnson County and Tarrant County
        </h2>
      </div>
      <div class="flex flex-wrap gap-3">
        {serviceAreas.map((area) => (
          <a
            href={`/${area.slug}`}
            class="text-sm px-3 py-1.5 rounded-full border hover:underline"
            style="border-color: var(--color-border-strong); color: var(--color-brand-accent); background-color: var(--color-surface-raised);"
          >
            {area.city}
          </a>
        ))}
        {['Johnson County', 'Tarrant County'].map((name) => (
          <span class="text-sm px-3 py-1.5 rounded-full border" style="border-color: var(--color-border-strong); color: var(--color-content-muted); background-color: var(--color-surface-raised);">
            {name}
          </span>
        ))}
      </div>
      <a href="/service-areas" class="inline-block mt-6 text-sm font-semibold hover:underline" style="color: var(--color-brand-navy);">
        See all service areas &rarr;
      </a>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-bold mb-4" style="font-family: var(--font-family-display); font-size: clamp(1.75rem, 4vw, 2.75rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
        Ready to stop worrying about your gutters?
      </h2>
      <p class="text-lg mb-8 max-w-xl mx-auto" style="color: var(--color-content-muted);">
        Free estimates, no contracts, {site.warranty} warranty. Call or fill out the form — we'll get back to you the same day.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="cta-primary inline-flex items-center justify-center px-8 py-4 rounded font-semibold">
          Get a Free Estimate
        </a>
        <a href={site.phoneLink} class="cta-secondary inline-flex items-center justify-center px-8 py-4 rounded font-semibold border">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
