---
// Homepage — hero, services summary, trust signals, process, service areas, CTA
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const title = 'Seamless Gutter Installation in Joshua, TX | Beacon Rain Control';
const description = 'Beacon Rain Control installs seamless aluminum gutters in Joshua, Burleson, Cleburne, and throughout Johnson County, TX. Free estimates. 5-year warranty. Call (817) 681-6041.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: site.name,
  telephone: site.phone,
  email: site.email,
  url: site.siteUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.state,
    postalCode: site.address.zip,
    addressCountry: 'US',
  },
  areaServed: site.serviceAreas,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.rating,
    reviewCount: site.reviewCount,
  },
  openingHours: 'Mo-Sa 08:00-18:00',
};
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section style="background-color: var(--color-surface-bg);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-brand-accent);">
          Joshua, TX &mdash; Johnson &amp; Tarrant County
        </p>
        <h1 class="font-bold leading-tight mb-6" style="font-family: var(--font-family-display); font-size: clamp(2rem, 5vw, 3.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
          Seamless Gutters That Protect Your Home for Years
        </h1>
        <p class="text-lg leading-relaxed mb-8" style="color: var(--color-content-muted);">
          When gutters fail, water finds the foundation. Beacon Rain Control installs custom-fitted seamless aluminum gutters — cut on-site, built to your roofline, backed by a 5-year warranty.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contact" class="cta-primary inline-flex items-center justify-center px-7 py-3.5 rounded font-semibold text-sm">
            Get a Free Estimate
          </a>
          <a href={site.phoneLink} class="cta-secondary inline-flex items-center justify-center px-7 py-3.5 rounded font-semibold text-sm border">
            Call {site.phone}
          </a>
        </div>
        <p class="text-xs mt-4" style="color: var(--color-content-muted);">No contracts &bull; Free estimates &bull; {site.warranty} warranty</p>
      </div>
    </div>
    <div class="h-px" style="background-color: var(--color-border);"></div>
  </section>

  <!-- Trust bar -->
  <section style="background-color: var(--color-surface-base); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-wrap items-center justify-center gap-8 md:gap-12">
        <div class="flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4" style="color: var(--color-brand-accent);" aria-hidden="true">
            <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
          </svg>
          <span class="text-sm font-semibold" style="color: var(--color-content-primary);">{site.rating}-star rated</span>
          <span class="text-sm" style="color: var(--color-content-muted);">({site.reviewCount} Google reviews)</span>
        </div>
        <div class="text-sm" style="color: var(--color-content-muted);">
          <span class="font-semibold" style="color: var(--color-content-primary);">{site.warranty} warranty</span> on all work
        </div>
        <div class="text-sm" style="color: var(--color-content-muted);">
          <span class="font-semibold" style="color: var(--color-content-primary);">Free estimates</span> &mdash; same-day quotes available
        </div>
        <div class="text-sm font-semibold" style="color: var(--color-content-primary);">
          Licensed &amp; insured
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">What We Do</p>
        <h2 class="font-bold" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
          Gutter services built around your home
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {site.services.map((service) => (
          <article class="service-card rounded-xl p-6 border flex flex-col gap-3">
            <h3 class="font-semibold text-base" style="color: var(--color-content-primary);">{service.name}</h3>
            <p class="text-sm leading-relaxed flex-1" style="color: var(--color-content-muted);">{service.description}</p>
            <a href={`/services#${service.slug}`} class="text-sm font-semibold hover:underline mt-auto" style="color: var(--color-brand-accent);">
              Learn more &rarr;
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Beacon -->
  <section class="py-20 md:py-24" style="background-color: var(--color-surface-base); border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">Why Beacon</p>
          <h2 class="font-bold mb-6" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
            Gutters you don't have to think about again
          </h2>
          <p class="text-base leading-relaxed mb-6" style="color: var(--color-content-muted);">
            Most gutter problems start with gutters that weren't built for the home they're on. Beacon Rain Control measures and cuts every gutter on-site — no pre-made sections, no exposed seams where water collects and leaks.
          </p>
          <p class="text-base leading-relaxed" style="color: var(--color-content-muted);">
            Every job is backed by a {site.warranty} warranty. If something isn't right, we come back and make it right.
          </p>
        </div>

        <div class="grid grid-cols-1 gap-4">
          {[
            { label: 'Same-day quotes', detail: 'Most estimates are turned around the same day you call.' },
            { label: 'On time, every time', detail: 'Customers consistently note we show up when we say we will.' },
            { label: 'Clean jobsite', detail: 'We haul everything out — no debris left behind.' },
            { label: '5-year warranty', detail: 'All gutter installations are backed by a written warranty.' },
          ].map((item) => (
            <div
              class="rounded-xl p-5 border flex gap-4 items-start"
              style="background-color: var(--color-surface-raised); border-color: var(--color-border-strong);"
            >
              <div
                class="mt-0.5 w-5 h-5 rounded-full flex items-center justify-center shrink-0"
                style="background-color: var(--color-brand-tint);"
                aria-hidden="true"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-3 h-3" style="color: var(--color-brand-accent);">
                  <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                </svg>
              </div>
              <div>
                <p class="text-sm font-semibold mb-0.5" style="color: var(--color-content-primary);">{item.label}</p>
                <p class="text-sm" style="color: var(--color-content-muted);">{item.detail}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="py-20 md:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-12 max-w-xl">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">How It Works</p>
        <h2 class="font-bold" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
          From first call to finished gutters
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
        {[
          { step: '01', title: 'Free estimate', body: 'Call or email — we come out, measure your roofline, and give you a straight quote. No pressure, no obligation.' },
          { step: '02', title: 'Custom fabrication on-site', body: 'We cut and form your gutters on-site from a continuous run of aluminum. Fit to your home, not off a shelf.' },
          { step: '03', title: 'Clean install, clean yard', body: 'Gutters go up, old materials come down, and we clean up before we leave. You get a warranty card and a clean gutterline.' },
        ].map((item) => (
          <div class="flex flex-col gap-4">
            <div class="text-3xl font-bold" style="font-family: var(--font-family-mono); color: var(--color-brand-accent); opacity: 0.5;" aria-hidden="true">
              {item.step}
            </div>
            <h3 class="text-lg font-semibold" style="color: var(--color-content-primary);">{item.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-content-muted);">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Service areas -->
  <section class="py-20 md:py-24" style="background-color: var(--color-surface-base); border-top: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="mb-10">
        <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">Where We Work</p>
        <h2 class="font-bold" style="font-family: var(--font-family-display); font-size: clamp(1.5rem, 3vw, 2.25rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
          Serving Johnson County and Tarrant County
        </h2>
      </div>
      <div class="flex flex-wrap gap-3">
        {site.serviceAreas.map((area) => (
          <span
            class="text-sm px-3 py-1.5 rounded-full border"
            style="border-color: var(--color-border-strong); color: var(--color-content-muted); background-color: var(--color-surface-raised);"
          >
            {area}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 md:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-bold mb-4" style="font-family: var(--font-family-display); font-size: clamp(1.75rem, 4vw, 2.75rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
        Ready to stop worrying about your gutters?
      </h2>
      <p class="text-lg mb-8 max-w-xl mx-auto" style="color: var(--color-content-muted);">
        Free estimates, no contracts, {site.warranty} warranty. Call or fill out the form — we'll get back to you the same day.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="cta-primary inline-flex items-center justify-center px-8 py-4 rounded font-semibold">
          Get a Free Estimate
        </a>
        <a href={site.phoneLink} class="cta-secondary inline-flex items-center justify-center px-8 py-4 rounded font-semibold border">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
</BaseLayout>
