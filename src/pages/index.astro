---
// Homepage — hero, services, trust signals, testimonials, process, gallery, service areas, CTA
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import site from '../data/site.json';
import serviceAreas from '../data/serviceAreas.json';

import heroImg        from '../assets/images/seamless-gutter.jpg';
import fabricationImg from '../assets/images/copper-gutter-fabrication.webp';
import galleryImg1    from '../assets/images/residential-seamless-gutter-installation1.jpg';
import galleryImg2    from '../assets/images/brc-seamlessgutter_installation.jpg';
import galleryImg3    from '../assets/images/seemlass-gutter-installation-2.jpg';
import ownerImg      from '../assets/images/brc-owner-tracy-neff-and-wife.jpg';

const title = 'Seamless Gutter Installation in Joshua, TX | Beacon Rain Control';
const description = 'Beacon Rain Control installs seamless aluminum gutters in Joshua, Burleson, Cleburne, and throughout Johnson County, TX. Free estimates. 5-year warranty. Call (817) 681-6041.';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: site.name,
  telephone: site.phone,
  email: site.email,
  url: site.siteUrl,
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.address.street,
    addressLocality: site.address.city,
    addressRegion: site.address.state,
    postalCode: site.address.zip,
    addressCountry: 'US',
  },
  areaServed: site.serviceAreas,
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: site.rating,
    reviewCount: site.reviewCount,
  },
  openingHours: 'Mo-Sa 08:00-18:00',
  image: [
    {
      '@type': 'ImageObject',
      contentUrl: site.siteUrl + '/src/assets/images/residential-seamless-gutter-installation1.jpg',
      url: site.siteUrl + '/src/assets/images/residential-seamless-gutter-installation1.jpg',
      description: 'Seamless gutter installation on a two-story brick home in Joshua, TX (March 2026)',
      caption: 'Joshua, TX — Seamless gutter install, March 2026',
    },
    {
      '@type': 'ImageObject',
      contentUrl: site.siteUrl + '/src/assets/images/brc-seamlessgutter_installation.jpg',
      url: site.siteUrl + '/src/assets/images/brc-seamlessgutter_installation.jpg',
      description: 'Beacon Rain Control technician installing seamless gutters on a stone home in Burleson, TX (February 2026)',
      caption: 'Burleson, TX — Stone home, Feb 2026',
    },
    {
      '@type': 'ImageObject',
      contentUrl: site.siteUrl + '/src/assets/images/seemlass-gutter-installation-2.jpg',
      url: site.siteUrl + '/src/assets/images/seemlass-gutter-installation-2.jpg',
      description: 'Gutter installation in progress on a brick ranch home in Cleburne, TX (January 2026)',
      caption: 'Cleburne, TX — Brick ranch, Jan 2026',
    },
  ],
};

const faqItems = [
  {
    q: 'How much does gutter installation cost in Joshua, TX?',
    a: 'Every home is different, so I don\'t give ballpark numbers without seeing the roofline first. What I can tell you is the estimate is free — I come out, measure the whole house, and give you a straight number before any work starts. Most Johnson County homeowners are surprised it\'s more affordable than they expected. Call or text and we\'ll set it up.',
  },
  {
    q: 'What\'s the difference between seamless and sectional gutters?',
    a: 'Sectional gutters come in pre-cut pieces joined together on the house. Every joint is a potential leak point — and Texas heat and temperature swings open those joints up over time. Seamless gutters are cut from a single continuous run of aluminum, custom-sized to your home, with no joints along the straight runs. The only connections are at the corners and downspouts, which are built to handle them. Fewer seams means fewer leaks.',
    link: { href: '/seamless-vs-sectional-gutters', text: 'Read the full breakdown →' },
  },
  {
    q: 'Do you install 5-inch or 6-inch gutters?',
    a: 'Both — and the right size depends on your roof. A 5-inch K-style gutter handles most standard residential rooflines. If you have a steeper pitch, a large roof area, or you\'ve had overflow problems in heavy Texas rain, 6-inch gutters move significantly more water. I\'ll look at your roof pitch and square footage and tell you which size makes sense — not just sell you the bigger one.',
    link: { href: '/5-inch-vs-6-inch-gutters', text: 'See how the decision gets made →' },
  },
  {
    q: 'How long does gutter installation take?',
    a: 'Most homes are done in a single day. We show up, fabricate the gutters on-site with our gutter machine, and install them the same visit — there\'s no waiting on pre-ordered materials. Larger homes or commercial jobs may run two days. You won\'t have a half-finished project sitting on your house overnight.',
  },
  {
    q: 'What does the 5-year warranty cover?',
    a: 'It covers our workmanship — the installation itself. If gutters we installed pull away from the fascia, sag, or leak at a connection we made, we come back and fix it at no charge. The warranty is written, not just verbal, and it goes with the installation. It doesn\'t cover storm damage or damage from lack of maintenance, but for normal use it\'s solid coverage.',
  },
  {
    q: 'Do you do gutter repairs, or only new installs?',
    a: 'Both. If your gutters are in decent shape but pulling away from the fascia, leaking at seams, or need new downspouts rerouted, a repair is often the right call. I\'ll tell you honestly whether a repair makes sense or whether you\'d be throwing money at gutters that need replacing. No pressure either way — I\'d rather give you the straight answer.',
  },
  {
    q: 'What areas do you serve?',
    a: 'We\'re based in Joshua and serve all of Johnson County — Burleson, Cleburne, Crowley, Alvarado, Grandview, Mansfield, and surrounding areas. We also serve parts of Tarrant County. If you\'re near the edge of our service area, give us a call and we\'ll let you know.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a },
  })),
};

const testimonials = [
  {
    quote: "Mr. Neff was courteous, responsive, and extremely knowledgeable when I reached out for a quote. His team did exceptional work and left the area clean when the job was complete. They provide a 5-year warranty on their work. Absolutely a great company — I will use Beacon Rain Control exclusively for all related work going forward.",
    author: "Beth James",
  },
  {
    quote: "Tracy was professional from beginning to end. They did a great job, showed up on time and cleaned up when they were done. I highly recommend Beacon Rain Control!",
    author: "Cecilia",
  },
  {
    quote: "Came out and got me a quote the same day I called. Professional and efficient, did a great job.",
    author: "Jake Bransford",
  },
];
---

<BaseLayout title={title} description={description}>

  <!-- Hero -->
  <section class="relative overflow-hidden" style="min-height: clamp(560px, 70vh, 760px);">

    <!-- Background image -->
    <Image
      src={heroImg}
      alt=""
      width={1400}
      height={800}
      class="absolute inset-0 w-full h-full object-cover object-center"
      loading="eager"
      aria-hidden="true"
    />

    <!-- Gradient overlay: heavy on left where text sits, lighter on right so the photo breathes -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(100deg, rgba(40,59,119,0.88) 0%, rgba(40,59,119,0.72) 45%, rgba(40,59,119,0.40) 100%), linear-gradient(to top, rgba(40,59,119,0.65) 0%, transparent 40%);"
      aria-hidden="true"
    ></div>

    <!-- Content -->
    <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center" style="min-height: clamp(560px, 70vh, 760px);">
      <div class="max-w-3xl py-20">
        <p class="text-xs font-semibold uppercase tracking-widest mb-4" style="color: var(--color-brand-accent);">
          Seamless Gutter Installation • Joshua, TX & Johnson County
        </p>
        <h1 class="font-bold leading-tight mb-6" style="font-family: var(--font-family-display); font-size: clamp(2rem, 5vw, 3.25rem); letter-spacing: -0.02em; color: #ffffff;">
          Stop Water Damage Before It Starts—Expert Gutter Installation in Joshua, TX
        </h1>
        <p class="text-lg leading-relaxed mb-8 max-w-xl" style="color: rgba(255,255,255,0.82);">
          Leaking or overflowing gutters can destroy your foundation, landscaping, and fascia. Beacon Rain Control installs seamless aluminum gutters—custom cut on-site for your home, built to handle Texas storms, and backed by a 5-year warranty. Serving Joshua, Burleson, Cleburne, and all of Johnson County.
        </p>
        
        <!-- Inline Quick Quote Form -->
        <form action="/contact" method="POST" class="mt-8 flex flex-col md:flex-row gap-3 p-3 rounded-xl border shadow-2xl" style="background-color: rgba(40, 59, 119, 0.80); backdrop-filter: blur(8px); border-color: rgba(255,255,255,0.20);">
          <input type="text" name="name" placeholder="Full Name" required aria-label="Full Name" class="w-full md:w-auto flex-1 rounded-md px-4 py-3 text-sm border" style="background-color: var(--color-surface-bg); border-color: var(--color-border); color: var(--color-content-primary);">
          <input type="tel" name="phone" placeholder="Phone Number" required aria-label="Phone Number" class="w-full md:w-auto flex-1 rounded-md px-4 py-3 text-sm border" style="background-color: var(--color-surface-bg); border-color: var(--color-border); color: var(--color-content-primary);">
          <select name="service" required aria-label="Service Needed" class="w-full md:w-auto flex-1 rounded-md px-4 py-3 text-sm border appearance-none" style="background-color: var(--color-surface-bg); border-color: var(--color-border); color: var(--color-content-primary);">
            <option value="" disabled selected>Service Needed</option>
            <option value="New Gutters">New Gutters</option>
            <option value="Gutter Guards">Gutter Guards</option>
            <option value="Repairs">Repairs</option>
          </select>
          <button type="submit" class="cta-primary w-full md:w-auto shrink-0 px-8 py-3 rounded-md font-semibold text-sm cursor-pointer shadow-md">
            Get Quote
          </button>
        </form>

        <!-- SMS CTA + warranty badge row -->
        <div class="flex flex-wrap items-center gap-x-5 gap-y-3 mt-6">
          <a
            href={`sms:+1${site.phone.replace(/\D/g,'')}&body=Hi%2C%20I%20need%20a%20free%20gutter%20estimate.%20Can%20you%20reach%20out%20when%20you%20get%20a%20chance%3F`}
            class="inline-flex items-center gap-1.5 text-sm font-semibold"
            style="color: var(--color-brand-accent);"
            aria-label="Send a text message to Beacon Rain Control for a free estimate"
          >
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" aria-hidden="true">
              <path fill-rule="evenodd" d="M2 5a2 2 0 012-2h12a2 2 0 012 2v7a2 2 0 01-2 2H6l-4 4V5z" clip-rule="evenodd" />
            </svg>
            Text for a Quote
          </a>
          <span aria-hidden="true" class="text-xs" style="color: rgba(255,255,255,0.30);">|</span>
          <div class="inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-xs font-semibold" style="color: rgba(255,255,255,0.90);">5-Year Written Warranty</span>
            <span class="text-xs" style="color: rgba(255,255,255,0.60);">on every installation</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom fade into next section -->
    <div class="absolute bottom-0 left-0 right-0 h-16" style="background: linear-gradient(to bottom, transparent, var(--color-surface-bg));" aria-hidden="true"></div>
  </section>

  <!-- Trust bar as marquee strip -->
  <section style="background-color: var(--color-surface-base); border-bottom: 1px solid var(--color-border);">
    <div class="overflow-x-hidden py-3" aria-label="Trust signals">
      <div class="relative w-full">
        <ul class="marquee-track flex items-center gap-8 min-w-max" role="list" aria-hidden="true">
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Star rating icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: #F59E0B;" aria-hidden="true">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">4.8 stars on Google</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">28 verified reviews</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Home icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.707 2.293a1 1 0 00-1.414 0l-7 7A1 1 0 003 11h1v5a2 2 0 002 2h2a1 1 0 001-1v-3h2v3a1 1 0 001 1h2a2 2 0 002-2v-5h1a1 1 0 00.707-1.707l-7-7z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Locally owned &amp; operated</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Serving Joshua, Burleson, Cleburne, Johnson County</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Shield-check icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">5-year written warranty</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">On every installation</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Phone icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Free same-day estimates</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Call or request online</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Badge-check icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Fully insured, TX-licensed</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Peace of mind, every job</span>
          </li>
          <!-- Duplicate for infinite scroll -->
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Star icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.868 2.884c-.321-.772-1.415-.772-1.736 0l-1.83 4.401-4.753.381c-.833.067-1.171 1.107-.536 1.651l3.62 3.102-1.106 4.637c-.194.813.691 1.456 1.405 1.02L10 15.591l4.069 2.485c.713.436 1.598-.207 1.404-1.02l-1.106-4.637 3.62-3.102c.635-.544.297-1.584-.536-1.65l-4.752-.382-1.831-4.401z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Top-rated in Joshua, TX</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">{site.rating} stars on Google &bull; {site.reviewCount} reviews</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Home icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M10.707 2.293a1 1 0 00-1.414 0l-7 7A1 1 0 003 11h1v5a2 2 0 002 2h2a1 1 0 001-1v-3h2v3a1 1 0 001 1h2a2 2 0 002-2v-5h1a1 1 0 00.707-1.707l-7-7z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Locally owned &amp; operated</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Serving Johnson County homeowners</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Shield-check icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">{site.warranty} warranty</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">On every installation</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Phone icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Free same-day estimates</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Call or request online</span>
          </li>
          <li class="inline-flex items-center gap-2 px-2">
            <!-- Badge-check icon -->
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-4 h-4 shrink-0" style="color: var(--color-brand-accent);" aria-hidden="true">
              <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span class="text-sm font-semibold" style="color: var(--color-content-primary);">Licensed &amp; insured</span>
            <span class="text-xs hidden sm:inline" style="color: var(--color-content-muted);">Peace of mind, every job</span>
          </li>
        </ul>
      </div>
    </div>
    <style>
      @media (min-width: 640px) {
        .marquee-track {
          display: flex;
          width: max-content;
          animation: marquee-infinite 32s linear infinite;
        }
        @keyframes marquee-infinite {
          0% { transform: translateX(0); }
          100% { transform: translateX(-50%); }
        }
      }
    </style>
  </section>

  <!-- Services -->
  <section class="py-24 md:py-32">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
