---
// Service areas hub — lists all city landing pages with links
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';
import serviceAreas from '../data/serviceAreas.json';

const title = 'Gutter Installation Service Areas | Beacon Rain Control — Johnson County, TX';
const description = 'Beacon Rain Control installs seamless aluminum gutters throughout Johnson County and Tarrant County, TX. Free estimates, 5-year written warranty. Find your city below.';
const canonical = `${site.siteUrl}/service-areas`;
---

<BaseLayout title={title} description={description} canonical={canonical}>

  <!-- Header -->
  <section class="py-14 md:py-20" style="background-color: var(--color-surface-base); border-bottom: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-brand-accent);">Where We Work</p>
      <h1 class="font-bold leading-tight mb-4 max-w-2xl" style="font-family: var(--font-family-display); font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
        Seamless Gutters in Johnson County and Tarrant County
      </h1>
      <p class="text-base leading-relaxed max-w-2xl" style="color: var(--color-content-muted);">
        Beacon Rain Control is based in Joshua, TX and serves communities across Johnson County, southern Tarrant County, and surrounding areas. Free same-day estimates, on-site fabrication, and a 5-year written warranty on every job.
      </p>
    </div>
  </section>

  <!-- City cards -->
  <section class="py-16 md:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {serviceAreas.map((area) => (
          <a
            href={`/${area.slug}`}
            class="group rounded-xl p-6 border flex flex-col gap-3 transition-colors duration-150"
            style="background-color: var(--color-surface-base); border-color: var(--color-border);"
          >
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color: var(--color-brand-accent);">{area.county}</p>
              <h2 class="font-bold text-lg group-hover:underline" style="font-family: var(--font-family-display); color: var(--color-content-primary);">
                {area.city}, TX
              </h2>
            </div>
            <p class="text-sm leading-relaxed flex-1" style="color: var(--color-content-muted);">
              {area.intro.split('.')[0]}.
            </p>
            <span class="text-sm font-semibold" style="color: var(--color-brand-accent);">
              Get a free estimate in {area.city} &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-20" style="background-color: var(--color-surface-base); border-top: 1px solid var(--color-border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-bold mb-4" style="font-family: var(--font-family-display); font-size: clamp(1.75rem, 4vw, 2.5rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
        Don't see your city?
      </h2>
      <p class="text-base mb-8 max-w-lg mx-auto" style="color: var(--color-content-muted);">
        We serve a wide area around Joshua. If you're not sure whether we come out to you, give us a call or send a text — we'll let you know.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact" class="cta-primary inline-flex items-center justify-center px-8 py-4 rounded font-semibold">
          Get a Free Estimate
        </a>
        <a href={site.phoneLink} class="cta-secondary inline-flex items-center justify-center px-8 py-4 rounded font-semibold border">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
