---
// Thank-you page — shown after estimate request form submission
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const title = 'Estimate Request Received | Beacon Rain Control';
const description = 'Thanks for reaching out. Beacon Rain Control will get back to you the same day.';
---

<BaseLayout title={title} description={description}>
  <section class="py-28 md:py-40">
    <div class="max-w-xl mx-auto px-4 text-center">
      <div
        class="w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-6"
        style="background-color: var(--color-brand-tint);"
        aria-hidden="true"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-6 h-6" style="color: var(--color-brand-accent);">
          <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
        </svg>
      </div>
      <h1 class="font-bold mb-4" style="font-family: var(--font-family-display); font-size: clamp(1.75rem, 4vw, 2.5rem); letter-spacing: -0.02em; color: var(--color-content-primary);">
        Request received
      </h1>
      <p class="text-lg mb-8" style="color: var(--color-content-muted);">
        Thanks for reaching out. We've received your information and will be in touch today.
      </p>
      
      <!-- What happens next -->
      <div class="p-6 md:p-8 rounded-xl border mb-8 text-left" style="background-color: var(--color-surface-base); border-color: var(--color-border-strong);">
        <h2 class="text-sm font-semibold uppercase tracking-widest mb-6" style="color: var(--color-brand-accent);">What happens next?</h2>
        <ol class="flex flex-col gap-5">
          <li class="flex gap-4 text-sm leading-relaxed" style="color: var(--color-content-muted);">
            <span class="font-mono font-bold" style="color: var(--color-content-primary);" aria-hidden="true">01</span>
            <span><strong>We'll call or text you</strong> at the number provided to schedule a time to come out and look at your home.</span>
          </li>
          <li class="flex gap-4 text-sm leading-relaxed" style="color: var(--color-content-muted);">
            <span class="font-mono font-bold" style="color: var(--color-content-primary);" aria-hidden="true">02</span>
            <span><strong>Tracy measures your roofline</strong> and gives you a straight, exact price. No pressure, no obligations.</span>
          </li>
          <li class="flex gap-4 text-sm leading-relaxed" style="color: var(--color-content-muted);">
            <span class="font-mono font-bold" style="color: var(--color-content-primary);" aria-hidden="true">03</span>
            <span><strong>If you approve</strong>, we typically schedule your custom installation within the week!</span>
          </li>
        </ol>
      </div>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="cta-secondary inline-flex items-center justify-center px-6 py-3.5 rounded font-semibold text-sm border">
          &larr; Back to home
        </a>
      </div>
    </div>
  </section>

  <!-- Conversion Tracking Placeholder -->
  <script is:inline>
    // If you add Google Ads, Analytics, or Meta Pixel, fire your conversion events here.
    // Example: window.dataLayer = window.dataLayer || []; window.dataLayer.push({'event': 'lead_submitted'});
  </script>
</BaseLayout>
